# =============================================================================
# DeepCue — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your real credentials
# =============================================================================

# --- Django ------------------------------------------------------------------
DJANGO_SECRET_KEY=your-secret-key-here-replace-with-50-random-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Controls which settings module is loaded (local | production)
DJANGO_SETTINGS_MODULE=deepcue_backend.settings.local

# --- Redis -------------------------------------------------------------------
# Single Redis instance serves both Celery (broker + result backend)
# and Django Channels (channel layer). Use separate DB indexes to isolate.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CHANNELS_REDIS_URL=redis://localhost:6379/2

# --- MongoDB Atlas -----------------------------------------------------------
# Full connection string from Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=deepcue

# --- ONNX Model Weight Paths -------------------------------------------------
# Relative to the project root. Drop Kaggle-exported .onnx files here.
VIDEO_MODEL_PATH=models/video/efficientnet_lstm.onnx
AUDIO_MODEL_PATH=models/audio/wav2vec2_classifier.onnx
TEXT_MODEL_PATH=models/text/xlm_roberta_sentiment.onnx
FUSION_MODEL_PATH=models/fusion/cross_modal_transformer.onnx

# --- Whisper Configuration ---------------------------------------------------
# Model size: tiny | base | small | medium | large
# "base" is recommended for CPU — best latency/accuracy trade-off for Hebrew
WHISPER_MODEL_SIZE=base
# Cache directory where Whisper downloads its weights on first run
WHISPER_CACHE_DIR=models/text/whisper_cache

# --- Inference Tuning --------------------------------------------------------
# Max frames buffered for LSTM temporal window (video pipeline)
VIDEO_LSTM_WINDOW_SIZE=30
# Audio chunk duration in seconds (audio + text pipelines)
AUDIO_CHUNK_SECONDS=3
# Fusion trigger interval in seconds (Celery Beat)
FUSION_INTERVAL_SECONDS=1

# --- Kaggle / Training (not used at runtime — for kaggle_scripts only) -------
WANDB_API_KEY=your-wandb-api-key-or-leave-blank
WANDB_MODE=disabled
